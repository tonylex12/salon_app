// Prisma schema for Salon Appointment System

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Entities

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // hasheada con bcryptjs
  name      String
  phone     String?
  role      Role     @default(CLIENT)
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
  staff        Staff?
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

model Staff {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio       String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule           Schedule[]
  services           StaffService[]
  appointments       Appointment[]
  scheduleExceptions ScheduleException[]
}

model Service {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int // en minutos
  price       Int // precio en centavos (ej: 2999 = $29.99)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staffServices StaffService[]
  appointments  Appointment[]
}

model StaffService {
  staffId   String
  serviceId String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([staffId, serviceId])
}

model Schedule {
  id        String   @id @default(cuid())
  staffId   String
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Domingo, 6=Sábado
  startTime DateTime @db.Time // tipo TIME de PostgreSQL
  endTime   DateTime @db.Time // tipo TIME de PostgreSQL
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, dayOfWeek])
}

model ScheduleException {
  id            String   @id @default(cuid())
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date // fecha específica
  isUnavailable Boolean  @default(true) // true=día sin disponibilidad (vacaciones, permiso, etc)
  reason        String? // ej: "Vacaciones", "Festivo", "Evento"
  createdAt     DateTime @default(now())

  @@unique([staffId, date])
}

model Appointment {
  id        String            @id @default(cuid())
  clientId  String
  staffId   String
  serviceId String
  date      DateTime // fecha y hora de inicio
  endTime   DateTime // fecha y hora de fin
  status    AppointmentStatus @default(PENDING)
  notes     String?           @db.Text
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  client  User    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([staffId, date, endTime]) // evita double-booking
  @@index([clientId])
  @@index([staffId])
  @@index([date])
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}
